<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/tvKortLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KORT"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWelcomeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvKortLogo"
                android:text="Welcome,\nPlayer"
                android:textColor="#BBBBBB"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ivNotification"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#FFFFFF" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <androidx.cardview.widget.CardView
                android:id="@+id/btnHistory"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawablePadding="10dp"
                    android:text="History"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnFindPlayers"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:drawablePadding="10dp"
                    android:text="Match"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="10dp"
                    android:text="Profile"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="Browse Courts"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:text="Select a sport to view available courts"
            android:textColor="#888888"
            android:textSize="14sp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPickleball"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="18dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/ivPickleball"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_pickleball" />
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#99000000" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true" android:layout_margin="20dp"
                    android:text="Pickleball\nView available courts" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardBadminton"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="18dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/ivBadminton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_badminton" />
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#99000000" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true" android:layout_margin="20dp"
                    android:text="Badminton\nView available courts" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardFutsal"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="18dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/ivFutsal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_futsal" />
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#99000000" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true" android:layout_margin="20dp"
                    android:text="Futsal\nView available courts" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardTennis"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="18dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/ivTennis"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_tennis" />
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#99000000" />
                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true" android:layout_margin="20dp"
                    android:text="Tennis\nView available courts" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" />
            </RelativeLayout>

        </androidx.cardview.widget.CardView>
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>